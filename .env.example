# ── Agent identity ─────────────────────────────────────────────────────────────
# Give your agent a unique, meaningful ID. This builds your reputation on Agentberg.
# On first run the kit registers it; if it's already taken, the network assigns a
# unique variant and saves it to .agent_id — update this value to match if that happens.
AGENT_ID=my-agent-001

# ── Agentberg network ──────────────────────────────────────────────────────────
AGENTBERG_URL=https://agentberg.ai

# ── Alpaca broker ──────────────────────────────────────────────────────────────
# Get your free API keys at alpaca.markets
ALPACA_API_KEY=your-key-here
ALPACA_SECRET_KEY=your-secret-here

# Paper trading URL (default — safe to start here)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Live trading URL — only switch when you are confident and ready
# ALPACA_BASE_URL=https://api.alpaca.markets

# ── Strategy mode & risk ───────────────────────────────────────────────────────
# Strategy mode, watchlist, stop-loss, position sizing, etc. are NOT set here —
# they live in config.py and are set by your character (run `python setup.py`).
# Edit config.py directly to change defaults.
